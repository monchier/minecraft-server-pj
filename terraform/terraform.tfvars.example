###############################################################################
# Copy this file to terraform.tfvars and adjust the values for your setup.
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored — keep secrets and personal settings there.
###############################################################################

aws_region   = "us-east-1"
project_name = "minecraft"

# --- Access -----------------------------------------------------------------
# Minecraft is open to the whole internet by default. Restrict if you want.
# allowed_minecraft_cidrs = ["0.0.0.0/0"]

# Lock SSH to your own IP. Find it with: curl ifconfig.me
# Leave empty to disable SSH entirely (you can still use SSM Session Manager).
allowed_ssh_cidrs = [] # e.g. ["203.0.113.7/32"]
ssh_key_name      = "" # e.g. "my-ec2-keypair"

# --- Sizing -----------------------------------------------------------------
# Modded servers need RAM. t3.large = 8GB, t3.xlarge = 16GB.
# Leave ~4 GB headroom below instance RAM for the OS and Docker.
instance_type       = "t3.xlarge"
server_memory       = "12G"
data_volume_size_gb = 30

# --- Minecraft / mods -------------------------------------------------------
# Loader must match every mod URL below.
# FORGE | NEOFORGE | FABRIC | QUILT | PAPER | VANILLA
mod_loader        = "FABRIC"
minecraft_version = "1.20.1"

# Direct download URLs for mod .jar files (Modrinth / CurseForge CDN links).
# Example: Fabric 1.20.1 with Time Controller (requires Fabric API).
mod_urls = [
  "https://cdn.modrinth.com/data/P7dR8mSH/versions/hu6gukgT/fabric-api-0.92.9%2B1.20.1.jar",
  "https://cdn.modrinth.com/data/HT32RjB5/versions/eYnGnT82/timecontrol-1.0.0%2B1.20.jar",
]

# Extra jars appended when CurseForge modpack sync is enabled (see below).
mod_urls_extra = []

# --- CurseForge modpack sync (optional) -------------------------------------
# When set (>0), mod URLs are resolved from a CurseForge modpack manifest
# instead of mod_urls. Requires an API key in the environment:
#   export CURSEFORGE_API_KEY="your-token"   # https://console.curseforge.com/
#
# curseforge_modpack_project_id = 123456
# curseforge_modpack_file_id    = 0   # 0 = latest release for minecraft_version
# mod_urls_extra = [
#   "https://cdn.modrinth.com/data/.../modrinth-only-mod.jar",
# ]
curseforge_modpack_project_id = 0
curseforge_modpack_file_id    = 0

motd        = "A modded Minecraft server, powered by Terraform"
difficulty  = "normal"
max_players = 20
ops         = ""          # Java Edition in-game name(s), comma-separated
seed        = ""          # e.g. "51685503"; empty = random

# --- Cost control -----------------------------------------------------------
# Stop the EC2 instance after this many minutes with no players online.
# Restart with: make start. Set to 0 to disable.
idle_shutdown_minutes = 120
